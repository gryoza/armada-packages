--- a/drivers/gpu/drm/msm/adreno/a6xx_preempt.h	1969-12-31 19:00:00.000000000 -0500
+++ b/drivers/gpu/drm/msm/adreno/a6xx_preempt.h	2026-06-11 19:07:55.652176398 -0400
@@ -0,0 +1,82 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/* Copyright (c) 2018, The Linux Foundation. All rights reserved. */
+/* Copyright (c) 2023 Collabora, Ltd. */
+/* Copyright (c) 2024 Valve Corporation */
