From: ROCKNIX
Subject: [armada] sm8750: add display (MDSS/DPU/DSI), DisplayPort, and GPU
 (Adreno 830/GMU) + GPU SMMU/gpucc/gxclkctl nodes

Rebased onto linux-7.0.11 from ROCKNIX SM8750 0036/0037/0038 plus the
adreno waiting-for-upstream bundle's sm8750.dtsi nodes. 7.0.11's sm8750.dtsi
ships no display/GPU; the A8xx GPU driver is already mainline, only these DT
nodes + the gpucc clock controller (separate patch) were missing.
---
--- a/arch/arm64/boot/dts/qcom/sm8750.dtsi
+++ b/arch/arm64/boot/dts/qcom/sm8750.dtsi
@@ -3,8 +3,12 @@
  * Copyright (c) 2024 Qualcomm Innovation Center, Inc. All rights reserved.
  */
 
+#include <dt-bindings/clock/qcom,dsi-phy-28nm.h>
 #include <dt-bindings/clock/qcom,rpmh.h>
+#include <dt-bindings/clock/qcom,sm8750-dispcc.h>
+#include <dt-bindings/clock/qcom,kaanapali-gxclkctl.h>
 #include <dt-bindings/clock/qcom,sm8750-gcc.h>
+#include <dt-bindings/clock/qcom,sm8750-gpucc.h>
 #include <dt-bindings/clock/qcom,sm8750-tcsr.h>
 #include <dt-bindings/clock/qcom,sm8750-videocc.h>
 #include <dt-bindings/dma/qcom-gpi.h>
@@ -2809,6 +2813,7 @@
 					reg = <2>;
 
 					usb_dp_qmpphy_dp_in: endpoint {
+						remote-endpoint = <&mdss_dp0_out>;
 					};
 				};
 			};
