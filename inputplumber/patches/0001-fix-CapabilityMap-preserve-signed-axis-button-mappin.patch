From 7c3f7bf2790ba046265b708da454884ed4d5dc98 Mon Sep 17 00:00:00 2001
From: virtudude <virtudude@protonmail.com>
Date: Sun, 31 May 2026 16:27:45 -0400
Subject: [PATCH] fix(CapabilityMap): preserve signed-axis button mapping

c3d535b switched ValueType::Button normalize to (raw-min)/(max-min), which maps
the negative endpoint of a signed-range axis (e.g. ABS_HAT0Y -1..1 dpad mapped
value_type: button + axis_direction: negative) to 0.0, so the abs()>0.5 press
threshold never fires and dpad up/left stop registering (repro: AYANEO Pocket
EVO). axis_direction already validates sign, so treat any non-zero raw as a
press for signed ranges; keep the normalize path for unsigned (ADC trigger) axes.
---
 src/input/event/evdev/translator.rs | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/input/event/evdev/translator.rs b/src/input/event/evdev/translator.rs
index dad3838..3db3ba8 100644
--- a/src/input/event/evdev/translator.rs
+++ b/src/input/event/evdev/translator.rs
@@ -504,7 +504,16 @@ impl EventTranslator {
         const IMU_SCALE: f64 = 0.01;
 
         match value_type {
-            ValueType::Button => normalize_unsigned_value(raw_value, info.minimum(), info.maximum()),
+            ValueType::Button => {
+                // signed-range axis-as-button (e.g. -1..1 dpad hat): axis_direction
+                // already validated sign, so any non-zero raw is a press; unsigned
+                // (ADC trigger) keeps the normalize path below.
+                if info.minimum() < 0 {
+                    if raw_value != 0 { 1.0 } else { 0.0 }
+                } else {
+                    normalize_unsigned_value(raw_value, info.minimum(), info.maximum())
+                }
+            }
             ValueType::Trigger => normalize_unsigned_value(raw_value, info.minimum(), info.maximum()),
             ValueType::JoystickX | ValueType::JoystickY => {
                 normalize_signed_value(raw_value, info.minimum(), info.maximum())
